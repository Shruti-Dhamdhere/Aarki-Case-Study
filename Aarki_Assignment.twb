            <run fontalignment='1' fontcolor='#555555' fontname='Arial' fontsize='9'>Organic: 11.8% (n=491) vs Content Network: 5.9% (n=290)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
