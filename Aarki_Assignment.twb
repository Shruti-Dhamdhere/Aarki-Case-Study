              <calculation class='tableau' formula='IF [CallStatus] = &quot;Closed&quot;&#10;OR [CallStatus] = &quot;EP Sent&quot;&#10;OR [CallStatus] = &quot;EP Received&quot;&#10;OR [CallStatus] = &quot;EP Confirmed&quot;&#10;THEN 1 ELSE 0 END' />
