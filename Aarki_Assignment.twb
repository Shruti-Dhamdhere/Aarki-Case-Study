    <worksheet name='Debt Level'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Arial' fontsize='12'>Debt Level is the #1 Conversion Driver (p = 0.006)</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#666666' fontname='Arial' fontsize='9'>$70K-$90K converts at 13.7% - Under $10K at just 5.0%</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Analyst_case_study_dataset_1_(1) (1))' name='federated.1lsycke01vbehi174fsek0qvmk52' />
          </datasources>
          <datasource-dependencies datasource='federated.1lsycke01vbehi174fsek0qvmk52'>
            <column caption='Is Closed' datatype='integer' name='[Calculation_2651846173615284224]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [CallStatus] = &quot;Closed&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='Is Bad Lead' datatype='integer' name='[Calculation_2651846173616324610]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [CallStatus] = &quot;Unable to contact - Bad Contact Information&quot;&#10;OR [CallStatus] = &quot;Contacted - Invalid Profile&quot;&#10;OR [CallStatus] = &quot;Contacted - Doesn&apos;t Qualify&quot;&#10;THEN 1 ELSE 0 END' />
            </column>
            <column caption='Debt Tier' datatype='string' name='[Calculation_2651846173661093894]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [DebtLevel] = &quot;7500-10000&quot; THEN &quot;01. Under $10K&quot;&#10;ELSEIF [DebtLevel] = &quot;7500-15000&quot; THEN &quot;02. $7.5K-$15K&quot;&#10;ELSEIF [DebtLevel] = &quot;10001-15000&quot; THEN &quot;03. $10K-$15K&quot;&#10;ELSEIF [DebtLevel] = &quot;15001-20000&quot; THEN &quot;04. $15K-$20K&quot;&#10;ELSEIF [DebtLevel] = &quot;20001-30000&quot; THEN &quot;05. $20K-$30K&quot;&#10;ELSEIF [DebtLevel] = &quot;30001-50000&quot; THEN &quot;06. $30K-$50K&quot;&#10;ELSEIF [DebtLevel] = &quot;50001-70000&quot; THEN &quot;07. $50K-$70K&quot;&#10;ELSEIF [DebtLevel] = &quot;70001-90000&quot; THEN &quot;08. $70K-$90K&quot;&#10;ELSEIF [DebtLevel] = &quot;90000-100000&quot; THEN &quot;09. $90K-$100K&quot;&#10;ELSEIF [DebtLevel] = &quot;More_than_100000&quot; THEN &quot;10. Over $100K&quot;&#10;END' />
            </column>
            <column caption='Is DQ' datatype='integer' name='[Calculation_2651846173854416908]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [CallStatus] = &quot;Contacted - Doesn&apos;t Qualify&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='Above Average' datatype='string' name='[Calculation_2651846173855285264]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([Calculation_2651846173615284224]) &gt; 0.081 THEN &quot;Above Avg&quot; ELSE &quot;Below Avg&quot; END' />
            </column>
            <column caption='Call Status' datatype='string' name='[CallStatus]' role='dimension' type='nominal' />
            <column caption='Debt Level' datatype='string' name='[DebtLevel]' role='dimension' type='nominal' />
            <column caption='Vendor Lead ID' datatype='string' name='[VendorLeadID]' role='dimension' type='nominal' />
