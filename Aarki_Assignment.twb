      <aliases enabled='yes' />
      <column caption='Ad Group' datatype='string' name='[AdGroup]' role='dimension' type='nominal' />
      <column caption='Address Score' datatype='string' name='[AddressScore]' role='dimension' type='nominal' />
      <column caption='Advertiser Campaign Name' datatype='string' name='[AdvertiserCampaignName]' role='dimension' type='nominal' />
      <column caption='Is Closed' datatype='integer' name='[Calculation_2651846173615284224]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [CallStatus] = &quot;Closed&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Is Good Lead' datatype='integer' name='[Calculation_2651846173615603713]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [CallStatus] = &quot;Closed&quot;&#10;OR [CallStatus] = &quot;EP Sent&quot;&#10;OR [CallStatus] = &quot;EP Received&quot;&#10;OR [CallStatus] = &quot;EP Confirmed&quot;&#10;THEN 1 ELSE 0 END' />
      </column>
      <column caption='Is Bad Lead' datatype='integer' name='[Calculation_2651846173616324610]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [CallStatus] = &quot;Unable to contact - Bad Contact Information&quot;&#10;OR [CallStatus] = &quot;Contacted - Invalid Profile&quot;&#10;OR [CallStatus] = &quot;Contacted - Doesn&apos;t Qualify&quot;&#10;THEN 1 ELSE 0 END' />
      </column>
      <column caption='Lead Month' datatype='datetime' name='[Calculation_2651846173660729347]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [LeadCreated])' />
      </column>
      <column caption='Partner Clean' datatype='string' name='[Calculation_2651846173661020165]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LOWER([Partner]) = &quot;google&quot; THEN &quot;Google&quot;&#10;ELSEIF [Partner] = &quot;Call_Center&quot; THEN &quot;Call Center&quot;&#10;ELSEIF [Partner] = &quot;yahoo&quot; THEN &quot;Yahoo&quot;&#10;ELSE [Partner]&#10;END' />
      </column>
      <column caption='Debt Tier' datatype='string' name='[Calculation_2651846173661093894]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [DebtLevel] = &quot;7500-10000&quot; THEN &quot;01. Under $10K&quot;&#10;ELSEIF [DebtLevel] = &quot;7500-15000&quot; THEN &quot;02. $7.5K-$15K&quot;&#10;ELSEIF [DebtLevel] = &quot;10001-15000&quot; THEN &quot;03. $10K-$15K&quot;&#10;ELSEIF [DebtLevel] = &quot;15001-20000&quot; THEN &quot;04. $15K-$20K&quot;&#10;ELSEIF [DebtLevel] = &quot;20001-30000&quot; THEN &quot;05. $20K-$30K&quot;&#10;ELSEIF [DebtLevel] = &quot;30001-50000&quot; THEN &quot;06. $30K-$50K&quot;&#10;ELSEIF [DebtLevel] = &quot;50001-70000&quot; THEN &quot;07. $50K-$70K&quot;&#10;ELSEIF [DebtLevel] = &quot;70001-90000&quot; THEN &quot;08. $70K-$90K&quot;&#10;ELSEIF [DebtLevel] = &quot;90000-100000&quot; THEN &quot;09. $90K-$100K&quot;&#10;ELSEIF [DebtLevel] = &quot;More_than_100000&quot; THEN &quot;10. Over $100K&quot;&#10;END' />
      </column>
      <column caption='Is Low Quality Debt' datatype='integer' name='[Calculation_2651846173661298695]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [DebtLevel] = &quot;7500-10000&quot; OR [DebtLevel] = &quot;More_than_100000&quot;&#10;THEN 1 ELSE 0 END' />
      </column>
      <column caption='Channel' datatype='string' name='[Calculation_2651846173661388808]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [PublisherCampaignName] = &quot;DebtReductionCallCenter&quot; &#10;THEN &quot;Call Center&quot; ELSE &quot;Online Form&quot; END' />
      </column>
      <column caption='Ad Type' datatype='string' name='[Calculation_2651846173661437961]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([AdvertiserCampaignName], &quot;branded&quot;) &#10;THEN &quot;Branded&quot; ELSE &quot;Generic&quot; END' />
      </column>
      <column caption='Form Pages' datatype='string' name='[Calculation_2651846173661523978]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([WidgetName], &quot;2DC&quot;) THEN &quot;2-Page Form&quot;&#10;ELSE &quot;1-Page Form&quot;&#10;END' />
      </column>
      <column caption='Conversion Rate Label' datatype='string' name='[Calculation_2651846173661614091]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(ROUND(AVG([Calculation_2651846173615284224]) * 100, 1)) + &quot;%&quot;' />
      </column>
      <column caption='Is DQ' datatype='integer' name='[Calculation_2651846173854416908]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [CallStatus] = &quot;Contacted - Doesn&apos;t Qualify&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Is Unable to Contact' datatype='integer' name='[Calculation_2651846173854531597]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [CallStatus] = &quot;Unable to contact - Bad Contact Information&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Widget Design' datatype='string' name='[Calculation_2651846173854904334]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='REPLACE(&#10;  REPLACE([WidgetName], &quot;w-300250-DebtReduction1-&quot;, &quot;&quot;),&#10;  &quot;w-302252-DebtReduction1-&quot;, &quot;&quot;&#10;)' />
      </column>
      <column caption='Form Type' datatype='string' name='[Calculation_2651846173855195151]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([WidgetName], &quot;2DC&quot;) THEN &quot;2-Page Form&quot; ELSE &quot;1-Page Form&quot; END' />
      </column>
      <column caption='Above Average' datatype='string' name='[Calculation_2651846173855285264]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_2651846173615284224]) &gt; 0.081 THEN &quot;Above Avg&quot; ELSE &quot;Below Avg&quot; END' />
      </column>
      <column caption='Landing Page Short' datatype='string' name='[Calculation_2651846173855391761]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([LandingPageURL], &quot;index8&quot;) THEN &quot;index8 (Main)&quot;&#10;ELSEIF CONTAINS([LandingPageURL], &quot;index11&quot;) THEN &quot;index11&quot;&#10;ELSEIF CONTAINS([LandingPageURL], &quot;index12&quot;) THEN &quot;index12&quot;&#10;ELSEIF CONTAINS([LandingPageURL], &quot;CallCenter&quot;) THEN &quot;Call Center Page&quot;&#10;ELSE &quot;Other&quot;&#10;END' />
      </column>
      <column caption='Referral Type' datatype='string' name='[Calculation_2651846173855481874]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ReferralDomain] = &quot;www.google.com&quot; THEN &quot;Google Organic Search&quot;&#10;ELSEIF [ReferralDomain] = &quot;googleads.g.doubleclick.net&quot; THEN &quot;Google Content Network&quot;&#10;ELSEIF CONTAINS(LOWER(STR([ReferralDomain])), &quot;search&quot;) THEN &quot;Other Search&quot;&#10;ELSE &quot;Other/Direct&quot;&#10;END' />
      </column>
