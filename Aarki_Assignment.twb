    <worksheet name='Widget Creative'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Arial' fontsize='12'>BlueMeter Converts at 14.1% With 0% Disqualification Rate</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#555555' fontname='Arial' fontsize='9'>It was 15% of ad rotation in April, then pulled entirely after May</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Analyst_case_study_dataset_1_(1) (1))' name='federated.1lsycke01vbehi174fsek0qvmk52' />
